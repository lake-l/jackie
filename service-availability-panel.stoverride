name: YouTube Gemini ChatGPT Availability
desc: Collapsed tiles for checking YouTube, Gemini, and ChatGPT availability.
author: Codex
homepage: https://example.com
category: Tools

tiles:
  - name: YouTube-Check
    title: YouTube
    icon: https://fastly.jsdelivr.net/gh/StashNetworks/misc@main/collapsed-tiles/img/youtube.png
    collapsed: true
    url: https://www.youtube.com

  - name: Gemini-Check
    title: Gemini
    icon: https://www.gstatic.com/lamda/images/gemini_sparkle_aurora_33f86dc0c0257da337c63.svg
    collapsed: true
    url: https://gemini.google.com

  - name: ChatGPT-Check
    title: ChatGPT
    icon: https://fastly.jsdelivr.net/gh/StashNetworks/misc@main/collapsed-tiles/img/chatgpt.png
    collapsed: true
    url: https://chatgpt.com

script-providers:
  YouTube-Check:
    url: https://raw.githubusercontent.com/lake-l/jackie/main/scripts/youtube.js
  Gemini-Check:
    url: https://raw.githubusercontent.com/lake-l/jackie/main/scripts/gemini.js
  ChatGPT-Check:
    url: https://raw.githubusercontent.com/lake-l/jackie/main/scripts/chatgpt.js

